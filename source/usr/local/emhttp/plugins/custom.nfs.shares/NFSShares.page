<script>
$(function () {
    // ── Delegated delete handler — uses data attribute to avoid inline-onclick
    // htmlspecialchars not escaping newlines/control chars in JS string context.
    $(document).on('click', '.js-nfs-delete', function (e) {
        e.preventDefault();
        nfsDeleteShare($(this).data('shareName'));
    });

    // ── Enable/disable toggles (AC-NFS-01.4): post to api.php?action=toggle,
    // update row visual state from JSON response WITHOUT full page reload.
    $('.nfs-share-toggle').switchButton({
        on_label:  '',
        off_label: ''
    }).on('change', function () {
        var $toggle  = $(this);
        var name     = $toggle.data('share');
        var enabled  = $toggle.is(':checked');
        var $row     = $toggle.closest('tr');
        var $wrapper = $toggle.closest('.switch-button-background');

        // Disable during the request to prevent double-clicks.
        $toggle.prop('disabled', true);
        $wrapper.css('opacity', '0.6');

        $.post('/plugins/custom.nfs.shares/api.php', {
            action:  'toggle',
            name:    name,
            enabled: enabled ? 'true' : 'false'
        }, function (response) {
            $toggle.prop('disabled', false);
            $wrapper.css('opacity', '');

            if (response.success) {
                // Update row opacity from the authoritative server-side value.
                $row.toggleClass('share-disabled', !response.enabled);
                if (response.warning) {
                    showWarning(response.warning);
                } else {
                    showSuccess(enabled ? '_(Export enabled)_' : '_(Export disabled)_');
                }
            } else {
                // Revert toggle on error.
                $toggle.prop('checked', !enabled).trigger('change.switchButton');
                showError(response.error || '_(Failed to toggle export)_');
            }
        }, 'json').fail(function () {
            $toggle.prop('disabled', false);
            $wrapper.css('opacity', '');
            $toggle.prop('checked', !enabled).trigger('change.switchButton');
            showError('_(Failed to toggle export)_');
        });
    });
});

function nfsDeleteShare(shareName) {
    swal({
        title:             '_(Confirm Delete)_',
        text:              '_(Are you sure you want to delete the export)_ "' + shareName + '"?',
        type:              'warning',
        showCancelButton:  true,
        confirmButtonText: '_(Delete)_',
        cancelButtonText:  '_(Cancel)_'
    }, function (confirmed) {
        if (!confirmed) { return; }
        $.post('/plugins/custom.nfs.shares/api.php', {
            action: 'delete',
            name:   shareName
        }, function (response) {
            if (response.success) {
                showSuccess(response.message || '_(Export deleted)_');
                setTimeout(function () { location.reload(); }, 1000);
            } else {
                showError(response.error || '_(Failed to delete export)_');
            }
        }, 'json').fail(function (xhr) {
            var msg = '_(Error deleting export)_';
            try {
                var r = JSON.parse(xhr.responseText);
                if (r.error) { msg = r.error; }
            } catch (e) { /* ignore */ }
            showError(msg);
        });
    });
}

function nfsReload() {
    var $btn = $('#nfs-reload-btn');
    var orig = $btn.val();
    $btn.prop('disabled', true).val('_(Reloading...)_');

    $.post('/plugins/custom.nfs.shares/api.php', { action: 'reload' }, function (response) {
        if (response.success) {
            showSuccess('_(NFS exports reloaded successfully)_');
        } else if (response.escalated) {
            showError('_(NFS reload failed and rollback also failed — manual intervention required: )_' + response.error);
        } else {
            showError(response.error || '_(Failed to reload NFS exports)_');
        }
        $btn.prop('disabled', false).val(orig);
    }, 'json').fail(function () {
        showError('_(Failed to reload NFS exports)_');
        $btn.prop('disabled', false).val(orig);
    });
}

function nfsExportConfig() {
    $.get('/plugins/custom.nfs.shares/api.php?action=exportConfig', function (response) {
        if (response.success) {
            var json = JSON.stringify(response.config, null, 2);
            window._nfsExportedConfig = json;
            swal({
                title:             '_(Export Configuration)_',
                text:              '<textarea readonly style="width:100%;height:200px;">'
                                   + json + '</textarea>'
                                   + '<br><button type="button" class="btn" id="nfsDownloadCfgBtn"'
                                   + ' style="margin-top:10px">_(Download as File)_</button>',
                html:              true,
                confirmButtonText: '_(Close)_'
            });
            setTimeout(function () {
                $('#nfsDownloadCfgBtn').on('click', function () {
                    var blob = new Blob([window._nfsExportedConfig], { type: 'application/json' });
                    var url  = URL.createObjectURL(blob);
                    var a    = document.createElement('a');
                    a.href     = url;
                    a.download = 'custom-nfs-shares.json';
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                });
            }, 100);
        } else {
            showError(response.error || '_(Export failed)_');
        }
    }, 'json');
}

function nfsImportConfig() {
    swal({
        title:             '_(Import Configuration)_',
        text:              '<textarea id="nfsImportJson" style="width:100%;height:200px;"'
                           + ' placeholder="_(Paste JSON configuration here)_"></textarea>'
                           + '<br><button type="button" class="btn" id="nfsImportFileBtn"'
                           + ' style="margin-top:10px">_(Import from File)_</button>',
        html:              true,
        showCancelButton:  true,
        confirmButtonText: '_(Import)_',
        cancelButtonText:  '_(Cancel)_',
        closeOnConfirm:    false,
        allowOutsideClick: false
    }, function (confirmed) {
        if (!confirmed) { return; }
        var content = $('#nfsImportJson').val();
        if (!content) {
            swal.showInputError('_(Please paste a configuration or use Import from File)_');
            return false;
        }
        nfsDoImport(content);
    });

    setTimeout(function () {
        $('#nfsImportFileBtn').on('click', function () {
            var $file = $('<input type="file" accept=".json" style="display:none">');
            $('body').append($file);
            $file.on('change', function (e) {
                var file = e.target.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function (ev) {
                        var content = ev.target.result;
                        $('#nfsImportJson').val(content);
                        nfsDoImport(content);
                    };
                    reader.readAsText(file);
                }
                $file.remove();
            });
            $file.click();
        });
    }, 100);
}

function nfsDoImport(content) {
    try { JSON.parse(content); } catch (err) {
        try { swal.showInputError('_(Invalid JSON format)_'); } catch (e) { /* modal may be closed */ }
        showError('_(Invalid JSON format)_');
        return;
    }
    $.post('/plugins/custom.nfs.shares/api.php', {
        action: 'importConfig',
        config: content
    }, function (response) {
        if (response.success) {
            try { swal.close(); } catch (e) { /* ignore */ }
            if (response.warning) {
                showWarning('_(Config imported — )_' + response.warning);
            } else {
                showSuccess('_(Configuration imported successfully)_');
            }
            setTimeout(function () { location.reload(); }, 1200);
        } else {
            var msg = response.error || '_(Import failed)_';
            try { swal.showInputError(msg); } catch (e) { /* ignore */ }
            showError(msg);
        }
    }, 'json').fail(function (xhr) {
        var msg = '_(Import failed)_';
        try {
            var r = JSON.parse(xhr.responseText);
            if (r && r.error) { msg = r.error; }
        } catch (e) { msg = '_(Server error)_: ' + xhr.status; }
        try { swal.showInputError(msg); } catch (e) { /* ignore */ }
        showError(msg);
    });
}
</script>
