<script>
$(function() {
    var API = '/plugins/custom.nfs.shares/api.php';

    // Settings form — AJAX save, then reload so Cond-gated menu updates.
    $('#nfsSettingsForm').on('submit', function(e) {
        e.preventDefault();
        $.post(API + '?action=saveSettings', $(this).serialize(), function(response) {
            if (response.success) {
                showSuccess('_(Settings saved)_');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                showError(response.error || '_(Failed to save settings)_');
            }
        }, 'json').fail(function() { showError('_(Request failed)_'); });
    });

    window.nfsExportConfig = function() {
        $.get(API + '?action=exportConfig', function(response) {
            if (!response.success) { showError(response.error); return; }
            var blob = new Blob([JSON.stringify(response.config, null, 2)], { type: 'application/json' });
            var a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'custom-nfs-shares-config.json';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }, 'json');
    };

    window.nfsShowImport = function() { $('#nfsImportArea').show(); };

    window.nfsDoImport = function() {
        var json = $('#nfsImportJson').val();
        if (!json) { showError('_(Paste the exported JSON first)_'); return; }
        $.post(API + '?action=importConfig', { config: json }, function(response) {
            if (response.success) {
                showSuccess(response.warning ? '_(Imported with warning:)_ ' + response.warning : '_(Configuration imported)_');
                setTimeout(function() { location.reload(); }, 1000);
            } else {
                showError(response.error || '_(Import failed)_');
            }
        }, 'json').fail(function(xhr) {
            var msg = '_(Import failed)_';
            try { msg = JSON.parse(xhr.responseText).error || msg; } catch (err) { /* keep default */ }
            showError(msg);
        });
    };

    window.nfsCreateBackup = function() {
        $.post(API + '?action=createBackup', {}, function(response) {
            if (response.success) {
                showSuccess('_(Backup created:)_ ' + response.filename);
                setTimeout(function() { location.reload(); }, 800);
            } else {
                showError(response.error || '_(Backup failed)_');
            }
        }, 'json');
    };

    window.nfsRestoreBackup = function(filename) {
        swal({
            title: '_(Restore backup)_?',
            text: '_(This will replace the current shares and reload NFS exports.)_',
            type: 'warning',
            showCancelButton: true,
            confirmButtonText: '_(Restore)_',
            cancelButtonText: '_(Cancel)_'
        }, function(confirmed) {
            if (!confirmed) { return; }
            $.post(API + '?action=restoreBackup', { filename: filename }, function(response) {
                if (response.success) {
                    showSuccess('_(Backup restored)_');
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    showError(response.error || '_(Restore failed)_');
                }
            }, 'json');
        });
    };

    window.nfsDeleteBackup = function(filename) {
        swal({
            title: '_(Delete backup)_?',
            text: filename,
            type: 'warning',
            showCancelButton: true,
            confirmButtonText: '_(Delete)_',
            cancelButtonText: '_(Cancel)_'
        }, function(confirmed) {
            if (!confirmed) { return; }
            $.post(API + '?action=deleteBackup', { filename: filename }, function(response) {
                if (response.success) {
                    showSuccess('_(Backup deleted)_');
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    showError(response.error || '_(Delete failed)_');
                }
            }, 'json');
        });
    };
});
</script>
